#!/bin/sh

jobs=1
while getopts "j:" opt; do
  case "$opt" in
    j) jobs="$OPTARG" ;;
    *) exit 1 ;;
  esac
done

test_one=$(dirname "$0")/test-exercise
exercises=$(dirname "$(dirname "$0")")/exercises

failed_file=$(mktemp)
trap 'rm -f "$failed_file"' EXIT

# shellcheck disable=SC2016 # $1, $2, $3 are evaluated by the inner sh -c.
printf '%s\n' "$exercises"/practice/*/ | xargs -P "$jobs" -I{} sh -c '
  if ! "$1" "$3"; then
    basename "$3" >> "$2"
  fi
' _ "$test_one" "$failed_file" "{}"

if [ -s "$failed_file" ]; then
  echo "The following exercises failed"
  cat "$failed_file"
  exit 1
fi
