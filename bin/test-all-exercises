#!/bin/sh

jobs=1
while getopts "j:" opt; do
  case "$opt" in
    j) jobs="$OPTARG" ;;
    *) exit 1 ;;
  esac
done

test_one=$(dirname "$0")/test-exercise
exercises=$(dirname "$(dirname "$0")")/exercises

failed_file=$(mktemp)
trap 'rm -f "$failed_file"' EXIT

# shellcheck disable=SC2016
cmd=$(printf '"%s" "$1" || basename "$1" >> "%s"' "$test_one" "$failed_file")
printf '%s\n' "$exercises"/practice/*/ | xargs -P "$jobs" -I{} sh -c "${cmd}" _ "{}"

if [ -s "$failed_file" ]; then
  echo "The following exercises failed"
  cat "$failed_file"
  exit 1
fi
